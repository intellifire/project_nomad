# Project Nomad — Intellifire UAT
# Generated via: op inject -i .env.template.uat -o .env --force

# ============================================
# Image pins (managed via release manifest)
# ============================================
NOMAD_IMAGE_TAG=latest
FIRESTARR_IMAGE=ghcr.io/cwfmf/firestarr-cpp/firestarr:v0.9.5.10

# ============================================
# Deployment mode
# ============================================
NOMAD_AGENCY_ID=gnwt-uat
NODE_ENV=production

# ============================================
# FireSTARR dataset (path on the host)
# ============================================
FIRESTARR_DATASET_PATH=/srv/intellifire/firestarr_data
NOMAD_DATA_PATH=/srv/intellifire/firestarr_data
FIRESTARR_EXECUTION_MODE=docker

# ============================================
# Ports
# ============================================
NOMAD_FRONTEND_HOST_PORT=4901
NOMAD_BACKEND_HOST_PORT=4901
PORT=3001

# ============================================
# Auth — Nomad sits behind EM3 backend
# ============================================
NOMAD_AUTH_MODE=simple
VITE_AUTH_MODE=simple

# ============================================
# Frontend
# ============================================
VITE_MAPBOX_TOKEN=op://Prod RO/Mapbox/access_token
VITE_API_BASE_URL=

# ============================================
# CFS FireSTARR WMS layer auth
# ============================================
CFS_FIRESTARR_AUTHKEY=op://UAT/UAT Nomad/cfs_firestarr_authkey
