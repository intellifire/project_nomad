# Project Nomad — Local Development (Intellifire)
# Generated via: op inject -i .env.template -o .env --force
#
# Local dev should use upstream's docker-compose.yaml + docker-compose.dev.yaml
# (which builds from source). The intellifire compose file is for staging+ only.

# ============================================
# FireSTARR
# ============================================
FIRESTARR_IMAGE=ghcr.io/cwfmf/firestarr-cpp/firestarr:v0.9.5.10
# Local dev: dataset path is whatever you downloaded to via install-firestarr-dataset.sh
FIRESTARR_DATASET_PATH=/Users/sjordison/firestarr_data
NOMAD_DATA_PATH=/Users/sjordison/firestarr_data
FIRESTARR_EXECUTION_MODE=docker

# ============================================
# Deployment mode
# ============================================
NOMAD_AGENCY_ID=gnwt-local
NODE_ENV=development

# ============================================
# Ports
# ============================================
NOMAD_FRONTEND_HOST_PORT=4901
NOMAD_BACKEND_HOST_PORT=4901
PORT=3001

# ============================================
# Auth — none for local dev
# ============================================
NOMAD_AUTH_MODE=none
VITE_AUTH_MODE=none

# ============================================
# Frontend
# ============================================
VITE_MAPBOX_TOKEN=op://Prod RO/Mapbox/access_token
VITE_API_BASE_URL=

# ============================================
# CFS FireSTARR WMS layer auth
# ============================================
CFS_FIRESTARR_AUTHKEY=op://Local dev/Local dev Nomad/cfs_firestarr_authkey
