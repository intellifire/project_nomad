# Project Nomad — Intellifire Staging
# Generated via: op inject -i .env.template.staging -o .env --force
#
# This template is for the SLIMMED production-style compose file
# (docker-compose.intellifire.yaml). It pulls our pre-built image
# from ghcr.io/intellifire/project_nomad rather than building locally.

# ============================================
# Image pins (managed via release manifest)
# ============================================
NOMAD_IMAGE_TAG=latest
# FireSTARR upstream image — pin to a tested version, never :latest.
# v0.9.6+ has known TIFF corruption (upstream issue #184).
FIRESTARR_IMAGE=ghcr.io/cwfmf/firestarr-cpp/firestarr:v0.9.5.10

# ============================================
# Deployment mode
# ============================================
# ACN = Agency Centric Nomad (multi-agency aware)
# Even in ACN we use SQLite for now (simpler ops, fits single-instance).
NOMAD_AGENCY_ID=gnwt-staging
NODE_ENV=production

# ============================================
# FireSTARR dataset (path on the host)
# ============================================
# Ansible role syncs the dataset from spyd.com to this path.
# Must be an absolute path. ~50GB.
FIRESTARR_DATASET_PATH=/srv/intellifire/firestarr_data
NOMAD_DATA_PATH=/srv/intellifire/firestarr_data
FIRESTARR_EXECUTION_MODE=docker

# ============================================
# Ports
# ============================================
NOMAD_FRONTEND_HOST_PORT=4901
NOMAD_BACKEND_HOST_PORT=4901
PORT=3001

# ============================================
# Auth — Nomad sits behind EM3 backend, so no public auth is needed.
# 'simple' = username tracking only.
# ============================================
NOMAD_AUTH_MODE=simple
VITE_AUTH_MODE=simple

# ============================================
# Frontend (Mapbox token is public-style — baked into the JS bundle,
# but managed via 1Password for change control)
# ============================================
# Shared Mapbox token — same item EasyMap3 uses (single source of truth).
VITE_MAPBOX_TOKEN=op://Prod RO/Mapbox/access_token
VITE_API_BASE_URL=

# ============================================
# CFS FireSTARR WMS layer auth (real secret)
# ============================================
CFS_FIRESTARR_AUTHKEY=op://Staging/Staging Nomad/cfs_firestarr_authkey
