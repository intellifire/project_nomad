{
  "name": "@nomad/frontend",
  "version": "0.2.6",
  "description": "Project Nomad - Fire Modeling GUI",
  "private": false,
  "type": "module",
  "main": "./dist/openNomad.umd.cjs",
  "module": "./dist/openNomad.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/openNomad.js",
      "require": "./dist/openNomad.umd.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:lib": "vite build --config vite.lib.config.ts",
    "preview": "vite preview",
    "lint": "eslint src/**/*.{ts,tsx}",
    "test": "vitest",
    "test:watch": "vitest watch",
    "tarball": "npm run build:lib && node scripts/validate-tarball.js && npm pack",
    "tarball:patch": "npm version patch --no-git-tag-version && npm run tarball"
  },
  "dependencies": {
    "@mapbox/mapbox-gl-draw": "^1.5.1",
    "@turf/turf": "^7.3.1",
    "mapbox-gl": "^3.16.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-rnd": "^10.5.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/mapbox__mapbox-gl-draw": "^1.4.9",
    "@types/mapbox-gl": "^3.4.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "@vitejs/plugin-react": "^4.3.3",
    "eslint": "^9.14.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "jsdom": "^27.3.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^2.1.4"
  }
}
